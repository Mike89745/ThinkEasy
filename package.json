{
  "name": "thinkeasy",
  "main": "expo-router/entry",
  "version": "1.0.0",
  "scripts": {
    "start": "expo start --clear",
    "test": "jest",
    "e2e:android:debug:build": "detox build -c android.debug",
    "e2e:android:debug:test": "detox test -c android.debug",
    "e2e:android:release:build": "detox build -c android.release",
    "e2e:android:release:test": "detox test -c android.release",
    "e2e:ios:debug:build": "detox build -c ios.debug",
    "e2e:ios:debug:test": "detox test -c ios.debug",
    "e2e:ios:release:build": "detox build -c ios.release",
    "e2e:ios:release:test": "detox test -c ios.release",
    "generate-api": "orval",
    "android": "expo run:android",
    "ios": "expo run:ios",
    "web": "expo start --web",
    "lint:check": "eslint .",
    "lint:fix": "eslint . --fix",
    "format": "prettier --write .",
    "fix": "npm run lint:fix && npm run format",
    "prepare": "husky || true"
  },
  "dependencies": {
    "@expo/html-elements": "^0.10.1",
    "@gluestack-ui/core": "^3.0.10",
    "@gluestack-ui/utils": "^3.0.11",
    "@legendapp/motion": "^2.4.0",
    "@react-native-async-storage/async-storage": "2.2.0",
    "@react-navigation/bottom-tabs": "^7.15.5",
    "@react-navigation/elements": "^2.9.10",
    "@react-navigation/native": "^7.1.33",
    "@tanstack/react-query": "^5.96.1",
    "buffer": "^6.0.3",
    "expo": "~55.0.9",
    "expo-blur": "~55.0.13",
    "expo-constants": "~55.0.9",
    "expo-dev-client": "~55.0.23",
    "expo-device": "~55.0.10",
    "expo-font": "~55.0.4",
    "expo-glass-effect": "~55.0.8",
    "expo-image": "~55.0.6",
    "expo-linking": "~55.0.9",
    "expo-router": "~55.0.8",
    "expo-splash-screen": "~55.0.13",
    "expo-status-bar": "~55.0.4",
    "expo-symbols": "~55.0.5",
    "expo-system-ui": "~55.0.11",
    "expo-web-browser": "~55.0.10",
    "jotai": "^2.19.0",
    "lucide-react-native": "^0.510.0",
    "nativewind": "^4.1.23",
    "orval": "^8.6.2",
    "react": "19.2.0",
    "react-aria": "^3.33.0",
    "react-dom": "19.2.0",
    "react-hook-form": "^7.72.0",
    "react-native": "0.83.4",
    "react-native-gesture-handler": "~2.30.0",
    "react-native-reanimated": "~4.2.1",
    "react-native-safe-area-context": "^5.6.1",
    "react-native-screens": "~4.23.0",
    "react-native-svg": "15.15.3",
    "react-native-web": "~0.21.0",
    "react-native-worklets": "^0.7.2",
    "react-stately": "^3.39.0",
    "tailwind-variants": "^0.1.20",
    "toastify-react-native": "^7.2.3"
  },
  "devDependencies": {
    "@config-plugins/detox": "^11.0.0",
    "@testing-library/react-native": "^13.3.3",
    "@types/detox": "^17.14.3",
    "@types/jest": "^29.5.14",
    "@types/react": "~19.2.2",
    "@typescript-eslint/eslint-plugin": "^8.58.0",
    "@typescript-eslint/parser": "^8.58.0",
    "babel-plugin-module-resolver": "^5.0.0",
    "detox": "^20.50.1",
    "eslint": "^8.57.1",
    "eslint-config-expo": "^55.0.0",
    "eslint-config-prettier": "^10.1.8",
    "husky": "^9.1.7",
    "jest": "^29.7.0",
    "jest-circus": "^30.3.0",
    "jest-expo": "~55.0.11",
    "lint-staged": "^16.4.0",
    "prettier": "^3.8.1",
    "prettier-plugin-tailwindcss": "^0.5.11",
    "tailwindcss": "^3.4.17",
    "ts-jest": "^29.4.9",
    "typescript": "~5.9.2"
  },
  "jest": {
    "preset": "jest-expo",
    "testPathIgnorePatterns": [
      "<rootDir>/node_modules/",
      "<rootDir>/e2e/"
    ],
    "moduleNameMapper": {
      "\\.css$": "<rootDir>/src/__mocks__/fileMock.js",
      "^@/components/ui/FormInput$": "<rootDir>/src/components/ui/FormInput.tsx",
      "^@/components/ui/(.*)$": "<rootDir>/src/components/ui/$1",
      "^@/assets/(.*)$": "<rootDir>/assets/$1",
      "^@/(.*)$": "<rootDir>/src/$1"
    },
    "transformIgnorePatterns": [
      "node_modules/(?!((jest-)?react-native|@react-native(-community)?)|expo(nent)?|@expo(nent)?/.*|@expo-google-fonts/.*|react-navigation|@react-navigation/.*|@sentry/react-native|native-base|react-native-svg|@gluestack-ui/.*|@legendapp/.*|react-aria|react-stately|nativewind|tailwind-variants)"
    ]
  },
  "lint-staged": {
    "*.{ts,tsx,js,jsx}": [
      "eslint --fix",
      "prettier --write"
    ],
    "*.{json,md,css}": [
      "prettier --write"
    ]
  },
  "private": true
}
